    {
      "parameters": {
        "jsCode": "const trig = $('Gmail Trigger CVs').item.json;\n\n// Manejo seguro de subject\nlet subjectRaw = trig.subject || trig.Subject || '';\nif (typeof subjectRaw !== 'string') subjectRaw = String(subjectRaw.text || subjectRaw.value || subjectRaw || '');\nconst subject = subjectRaw.trim();\n\n// Manejo seguro de from (objeto o string)\nlet fromRaw = trig.from || trig.From || '';\nif (typeof fromRaw === 'object' && fromRaw !== null) {\n  fromRaw = fromRaw.text || fromRaw.value || fromRaw.address || JSON.stringify(fromRaw);\n}\nconst from = String(fromRaw || '').trim();\n\nlet email = from, nombre = from;\nconst m = from.match(/(.*)<(.+)>/);\nif (m) { \n  nombre = m[1].replace(/[\"']/g, '').trim(); \n  email = m[2].trim(); \n}\n\nlet puesto = \"\";\nconst pm = subject.match(/Postulaci[oó]n\\s*[-:]\\s*(.+)/i);\nif (pm) puesto = pm[1].trim();\n\nconst texto = ($json.text || '').trim();\n\nreturn [{ \n  json: { \n    nombre_real: nombre || 'Desconocido', \n    email_real: email,\n    puesto_solicitado: puesto, \n    texto_cv_crudo: texto, \n    largo_texto: texto.length \n  } \n}];"
      },
