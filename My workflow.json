      "parameters": {
        "sendTo": "teomuhlenkamp@gmail.com",
        "subject": "={{ '[Screening IA] Aprobar ' + $('Anonimizar y Armar Prompt').item.json.candidato_id + ' - ' + $('Vacante').item.json.Puesto + ' (Score ' + $('Parsear Respuesta').item.json.resultado.score + ')' }}",
        "message": "=<h2>Revision de candidato requerida</h2><p><b>Candidato:</b> {{ $('Anonimizar y Armar Prompt').item.json.candidato_id }}<br><b>Vacante:</b> {{ $('Vacante').item.json.Puesto }}<br><b>Score IA:</b> {{ $('Parsear Respuesta').item.json.resultado.score }}/100<br><b>Recomendacion:</b> {{ $('Parsear Respuesta').item.json.resultado.recomendacion }}<br><b>Cumple excluyentes:</b> {{ $('Parsear Respuesta').item.json.resultado.cumple_excluyentes }}</p><p><b>Justificacion:</b> {{ $('Parsear Respuesta').item.json.resultado.justificacion }}</p><hr><p>Decision humana (obligatoria antes de contactar):</p><p><a href=\"{{ $execution.resumeUrl }}?decision=aprobar\" style=\"background:#2e7d32;color:#fff;padding:10px 18px;text-decoration:none;border-radius:6px;\">APROBAR</a>&nbsp;&nbsp;&nbsp;<a href=\"{{ $execution.resumeUrl }}?decision=rechazar\" style=\"background:#c62828;color:#fff;padding:10px 18px;text-decoration:none;border-radius:6px;\">RECHAZAR</a></p><p style=\"font-size:12px;color:#888\">Sistema de alto riesgo (Anexo III, AI Act). Decision registrada en auditoria.</p>",
        "options": {
          "appendAttribution": false
